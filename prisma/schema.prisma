// Carbon Footprint Awareness Platform — Prisma Schema
// Database: SQLite (zero-config, swap to PostgreSQL for production)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Auth Models (Auth.js v5 compatible) ───────────────────────────────────

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  role           String    @default("USER") // USER | ADMIN
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  profile        UserProfile?
  activities     CarbonActivity[]
  goals          CarbonGoal[]
  badges         UserBadge[]
  challenges     UserChallenge[]
  streaks        Streak[]
  aiReports      AIReport[]
  posts          CommunityPost[]
  comments       Comment[]
  likes          Like[]
  groups         GroupMember[]
  notifications  Notification[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── User Profile & Preferences ────────────────────────────────────────────

model UserProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio           String?
  location      String?
  dietType      String   @default("MIXED") // VEGAN | VEGETARIAN | PESCATARIAN | MIXED | HEAVY_MEAT
  householdSize Int      @default(1)
  transportMode String   @default("CAR") // CAR | ELECTRIC_CAR | PUBLIC_TRANSIT | BICYCLE | WALKING
  xp            Int      @default(0)
  level         Int      @default(1)
  totalCO2Saved Float    @default(0)
  currentStreak Int      @default(0)
  longestStreak Int      @default(0)
  theme         String   @default("SYSTEM") // LIGHT | DARK | SYSTEM
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─── Carbon Tracking ───────────────────────────────────────────────────────

model CarbonActivity {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    String   // TRAVEL | ELECTRICITY | FOOD | SHOPPING | WATER | DEVICE
  subCategory String   // e.g., car_petrol, bus, beef, etc.
  value       Float    // raw input value (km, kWh, kg, etc.)
  unit        String   // km, kWh, kg, liters, hours
  co2Amount   Float    // calculated CO2 in kg
  date        DateTime @default(now())
  notes       String?
  createdAt   DateTime @default(now())

  @@index([userId, date])
  @@index([userId, category])
}

model CarbonGoal {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  targetCO2  Float    // target reduction in kg CO2
  currentCO2 Float    @default(0)
  startDate  DateTime
  endDate    DateTime
  status     String   @default("ACTIVE") // ACTIVE | COMPLETED | FAILED | CANCELLED
  createdAt  DateTime @default(now())
}

// ─── Gamification ──────────────────────────────────────────────────────────

model Badge {
  id          String      @id @default(cuid())
  name        String      @unique
  description String
  icon        String      // emoji or icon name
  category    String      // STREAK | REDUCTION | CHALLENGE | COMMUNITY | SPECIAL
  requirement String      // JSON: { type, threshold }
  xpReward    Int         @default(0)
  users       UserBadge[]
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId  String
  badge    Badge    @relation(fields: [badgeId], references: [id])
  earnedAt DateTime @default(now())

  @@unique([userId, badgeId])
}

model Challenge {
  id           String          @id @default(cuid())
  title        String
  description  String
  category     String          // TRAVEL | ELECTRICITY | FOOD | SHOPPING | WATER | DEVICE
  targetValue  Float
  targetUnit   String
  xpReward     Int
  startDate    DateTime
  endDate      DateTime
  isDaily      Boolean         @default(false)
  participants UserChallenge[]
  createdAt    DateTime        @default(now())
}

model UserChallenge {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id])
  progress    Float     @default(0)
  status      String    @default("IN_PROGRESS") // IN_PROGRESS | COMPLETED | FAILED
  joinedAt    DateTime  @default(now())
  completedAt DateTime?

  @@unique([userId, challengeId])
}

model Streak {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  startDate DateTime
  endDate   DateTime?
  days      Int       @default(1)
  isActive  Boolean   @default(true)
}

// ─── AI Reports ────────────────────────────────────────────────────────────

model AIReport {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // WEEKLY | MONTHLY | INSIGHT
  content   String   // JSON or markdown content
  period    String   // e.g., "2025-W01", "2025-06"
  createdAt DateTime @default(now())
}

// ─── Community ─────────────────────────────────────────────────────────────

model CommunityPost {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  content   String
  type      String    @default("PROGRESS") // PROGRESS | ACHIEVEMENT | CHALLENGE | TIP | DISCUSSION
  imageUrl  String?
  likes     Like[]
  comments  Comment[]
  groupId   String?
  group     Group?    @relation(fields: [groupId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Comment {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime      @default(now())
}

model Like {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@unique([userId, postId])
}

model Group {
  id          String          @id @default(cuid())
  name        String
  description String?
  imageUrl    String?
  creatorId   String
  members     GroupMember[]
  posts       CommunityPost[]
  createdAt   DateTime        @default(now())
}

model GroupMember {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupId  String
  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  role     String   @default("MEMBER") // MEMBER | ADMIN | OWNER
  joinedAt DateTime @default(now())

  @@unique([userId, groupId])
}

// ─── Notifications ─────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // BADGE | CHALLENGE | STREAK | COMMUNITY | SYSTEM
  title     String
  message   String
  read      Boolean  @default(false)
  data      String?  // JSON metadata
  createdAt DateTime @default(now())
}
